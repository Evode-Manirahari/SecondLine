# SecondLine — environment variables. Copy to .env and fill in.

# --- LLM selection ---
# Leave LLM_PROVIDER empty to auto-pick Nemotron when NEMOTRON_LLM_URL is set,
# otherwise GPT-4.1. Set explicitly to "nemotron", "gpt", or "claude".
LLM_PROVIDER=

# OpenAI (GPT-4.1 fallback LLM; can also power the eval caller/judge)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Anthropic Claude — optional bot LLM (LLM_PROVIDER=claude) AND the default
# engine for the eval caller-simulator + hallucination judge when set.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
# For lower voice latency on the bot, try claude-haiku-4-5 or claude-sonnet-4-6.

# NVIDIA Nemotron (open-source LLM + ASR, hosted on AWS during the hackathon)
NEMOTRON_LLM_URL=
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
NEMOTRON_API_KEY=dummy
NEMOTRON_ENABLE_THINKING=
NVIDIA_ASR_URL=

# Gradium (STT + TTS)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=_6Aslh2DxfmnRLmP

# Twilio (telephony transport + outbound SMS to owner/customer)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# The shop owner's mobile — gets an SMS summary of every order + escalation.
OWNER_PHONE_NUMBER=

# --- Eval harness knobs (optional) ---
# Agent under test (defaults to nemotron when NEMOTRON_LLM_URL is set, else gpt):
# EVAL_AGENT_PROVIDER=nemotron   # or "gpt"
# EVAL_AGENT_MODEL=gpt-4.1
# Caller-simulator + judge (defaults to Claude when ANTHROPIC_API_KEY is set):
# EVAL_AUX_PROVIDER=claude       # or "openai"
# EVAL_AUX_MODEL=claude-opus-4-8 # or gpt-4.1-mini on the openai path
# EVAL_LATENCY_BUDGET_MS=4000
