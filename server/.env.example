# SecondLine — environment variables. Copy to .env and fill in.

# --- LLM selection ---
# Leave LLM_PROVIDER empty to auto-pick Nemotron when NEMOTRON_LLM_URL is set,
# otherwise GPT-4.1. Set explicitly to "nemotron" or "gpt" to force one.
LLM_PROVIDER=

# OpenAI (GPT-4.1 fallback LLM + powers the eval caller/judge)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# NVIDIA Nemotron (open-source LLM + ASR, hosted on AWS during the hackathon)
NEMOTRON_LLM_URL=
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
NEMOTRON_API_KEY=dummy
NEMOTRON_ENABLE_THINKING=
NVIDIA_ASR_URL=

# Gradium (STT + TTS)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=_6Aslh2DxfmnRLmP

# Twilio (telephony transport + outbound SMS to owner/customer)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# The shop owner's mobile — gets an SMS summary of every order + escalation.
OWNER_PHONE_NUMBER=

# --- Eval harness knobs (optional) ---
# EVAL_AGENT_PROVIDER=gpt        # or "nemotron" for the model shootout
# EVAL_AGENT_MODEL=gpt-4.1
# EVAL_AUX_MODEL=gpt-4.1-mini    # caller simulator + hallucination judge
# EVAL_LATENCY_BUDGET_MS=4000
